# ── Google Voice credentials ──────────────────────────────────
# Use a Google App Password, NOT your real Gmail password.
# Steps: myaccount.google.com → Security → App passwords → create one
GV_EMAIL=your-google-voice-gmail@gmail.com
GV_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Shared secret between this service and Supabase Edge Functions ──
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GV_SERVICE_SECRET=replace-with-64-char-hex-secret

# ── Supabase Edge Function URLs ──────────────────────────────
SUPABASE_SEND_REMINDERS_URL=https://tmpdsiuadafbkmldvlki.supabase.co/functions/v1/send-reminders
SUPABASE_INBOUND_SMS_URL=https://tmpdsiuadafbkmldvlki.supabase.co/functions/v1/inbound-sms
# Bulk PTI link rollout (admin-queued, wave-drained). Leave unset to disable.
SUPABASE_PTI_DRAIN_URL=https://tmpdsiuadafbkmldvlki.supabase.co/functions/v1/pti-queue
PTI_DRAIN_INTERVAL_MINUTES=5
# Dispatcher morning digest (bot fires 7:15 AM America/Chicago). Leave unset to disable.
SUPABASE_DISPATCHER_DIGEST_URL=https://tmpdsiuadafbkmldvlki.supabase.co/functions/v1/dispatcher-digest

# ── Service config ────────────────────────────────────────────
PORT=3000
REPLY_POLL_INTERVAL_MINUTES=3
LOG_LEVEL=info

# Texts this number "bot is ONLINE" on every successful start (fresh boot or
# watchdog recovery) and "shutting down" on a graceful stop. Leave unset to
# disable. Does not cover hard crashes/power loss — nothing left to send it.
ADMIN_ALERT_PHONE=+1XXXXXXXXXX
